FROM python:3.11-slim AS base

# ── System dependencies ────────────────────────────────────────────────────
RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
# Install heavy ML deps (torch, transformers, sentence-transformers, faiss)
RUN pip install --no-cache-dir -r requirements.txt

# ── Application code ───────────────────────────────────────────────────────
# Copy the top-level services package init so Python resolves the package correctly
COPY services/__init__.py ./services/__init__.py
COPY services/rag/ ./services/rag/
COPY monitoring/ ./monitoring/
COPY data/complaints/ ./data/complaints/

# RAG index and model directories are created at startup
RUN mkdir -p /app/rag/index /app/rag/llm

# ── Security: run as non-root ──────────────────────────────────────────────
RUN useradd -m appuser && chown -R appuser /app
USER appuser

# Set Hugging Face cache directory to a local path within the app workspace
ENV HF_HOME=/app/.cache/huggingface

# Pre-download the SentenceTransformer embedding model to avoid startup network delay
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2')"

# ── Health check (Azure uses this to detect container readiness) ───────────
HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=3 \
    CMD curl -f http://localhost:${PORT:-80}/health || exit 1

# Azure App Service routes port 80/443 — RAG listens on 80 for cloud deploy
EXPOSE 80

# PORT env-var is set by App Service; fall back to 80
CMD ["sh", "-c", "uvicorn services.rag.main:app --host 0.0.0.0 --port ${PORT:-80} --log-level info --timeout-keep-alive 120"]
