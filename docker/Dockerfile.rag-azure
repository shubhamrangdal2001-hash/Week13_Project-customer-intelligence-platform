FROM python:3.11-slim AS base

# ── System dependencies ────────────────────────────────────────────────────
RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
# Install heavy ML deps (torch, transformers, sentence-transformers, faiss)
RUN pip install --no-cache-dir -r requirements.txt

# ── Application code ───────────────────────────────────────────────────────
COPY services/rag/ ./services/rag/
COPY monitoring/ ./monitoring/
COPY data/complaints/ ./data/complaints/

# RAG index and model directories are created at startup
RUN mkdir -p /app/rag/index /app/rag/llm

# ── Security: run as non-root ──────────────────────────────────────────────
RUN useradd -m appuser && chown -R appuser /app
USER appuser

# Azure App Service routes port 80/443 — RAG listens on 80 for cloud deploy
EXPOSE 80

# PORT env-var is set by App Service; fall back to 80
CMD ["sh", "-c", "uvicorn services.rag.main:app --host 0.0.0.0 --port ${PORT:-80} --log-level info --timeout-keep-alive 120"]
