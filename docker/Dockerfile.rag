FROM python:3.11-slim AS base

# ── System dependencies ────────────────────────────────────────────────────
RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
# Install heavy ML deps (torch, transformers, sentence-transformers, faiss)
RUN pip install --no-cache-dir -r requirements.txt

# ── Application code ───────────────────────────────────────────────────────
COPY services/rag/ ./services/rag/
COPY monitoring/ ./monitoring/
COPY data/complaints/ ./data/complaints/

# RAG index and model directories are mounted as volumes at runtime (or download at startup)
RUN mkdir -p /app/rag/index /app/rag/llm

# ── Security: run as non-root ──────────────────────────────────────────────
RUN useradd -m appuser && chown -R appuser /app
USER appuser

# Set Hugging Face cache directory to a local path within the app workspace
ENV HF_HOME=/app/.cache/huggingface

# Pre-download the SentenceTransformer embedding model to avoid startup network delay
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2')"

EXPOSE 8001

# ── Start service ──────────────────────────────────────────────────────────
CMD ["uvicorn", "services.rag.main:app", \
     "--host", "0.0.0.0", "--port", "8001", \
     "--log-level", "info", \
     "--timeout-keep-alive", "120"]
